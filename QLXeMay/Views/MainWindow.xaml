<Window x:Class="QLXeMay.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        
        xmlns:v="clr-namespace:QLXeMay.Views.DanhMuc"
        xmlns:vm="clr-namespace:QLXeMay.ViewModels.DanhMuc"
        
        xmlns:vNghiepVu="clr-namespace:QLXeMay.Views.NghiepVu"
        xmlns:vmNghiepVu="clr-namespace:QLXeMay.ViewModels.NghiepVu"
        
        xmlns:vHeThong="clr-namespace:QLXeMay.Views.HeThong"
        xmlns:vmHeThong="clr-namespace:QLXeMay.ViewModels.HeThong"
        
        xmlns:vRoot="clr-namespace:QLXeMay.Views"
        xmlns:vmRoot="clr-namespace:QLXeMay.ViewModels"
        xmlns:helpers="clr-namespace:QLXeMay.Helpers"
        
        Title="Hệ thống Quản lý Cửa hàng Xe máy" Height="780" Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">

    <Window.Resources>
        <helpers:ImagePathConverter x:Key="ImagePathConverter" />
        <DataTemplate DataType="{x:Type vmRoot:TrangChuViewModel}">
            <vRoot:TrangChuView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HangXeViewModel}">
            <v:HangXeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NhanVienViewModel}">
            <v:NhanVienView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:XeMayViewModel}">
            <v:XeMayView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KhachHangViewModel}">
            <v:KhachHangView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmNghiepVu:HoaDonViewModel}">
            <vNghiepVu:HoaDonView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmHeThong:BackupRestoreViewModel}">
            <vHeThong:BackupRestoreView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NhaCungCapViewModel}">
            <v:NhaCungCapView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmHeThong:ThongTinCaNhanViewModel}">
            <vHeThong:ThongTinCaNhanView/>
        </DataTemplate>

        <!-- Style nút điều hướng sidebar -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="4,1">
                            <Grid>
                                <!-- Accent bar bên trái -->
                                <Border x:Name="accent"
                                        Width="3" HorizontalAlignment="Left"
                                        CornerRadius="0,2,2,0" Background="#2563EB"
                                        Visibility="Collapsed"/>
                                <ContentPresenter Margin="12,0,0,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg"     Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                                <Setter TargetName="accent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style Nút điều hướng con (trong Expander) -->
        <Style x:Key="SubNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="36,0,16,0"/>
        </Style>

        <!-- Style Expander cho Sidebar (Accordion Menu) -->
        <Style x:Key="SidebarExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              Content="{TemplateBinding Header}"
                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Foreground="{TemplateBinding Foreground}"
                                              FontWeight="Medium"
                                              FontSize="13.5"
                                              Padding="12,10"
                                              HorizontalContentAlignment="Stretch"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    <TextBlock x:Name="Arrow" Grid.Column="1" Text="▼" FontFamily="Segoe UI Symbol" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#64748B" FontSize="11" RenderTransformOrigin="0.5,0.5">
                                                        <TextBlock.RenderTransform>
                                                            <RotateTransform Angle="-90"/>
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#1E293B"/>
                                                    <Setter TargetName="Arrow" Property="Foreground" Value="#94A3B8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Focusable="false" Margin="0,0,0,4"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút đăng xuất (đỏ nhạt) -->
        <Style x:Key="LogoutButton" TargetType="Button">
            <Setter Property="Foreground"      Value="#F87171"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="4,0">
                            <ContentPresenter Margin="14,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3F1515"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="#0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo / Brand -->
                <Border Grid.Row="0" Padding="20,24,20,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0"/>
                            <GradientStop Color="#0F172A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <Border Background="#1D4ED8" CornerRadius="12"
                                Width="48" Height="48" HorizontalAlignment="Left">
                            <Image Source="/Images/Icons/motorcycle.png"
                                   Height="28" Width="28"/>
                        </Border>
                        <TextBlock Text="XE MÁY PRO"
                                   Foreground="White" FontSize="17" FontWeight="Bold"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding CurrentUserDisplayName, StringFormat=Xin chào \{0\}}"
                                   Foreground="#475569" FontSize="12" FontWeight="SemiBold"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                        Background="#1E293B" Margin="16,0"/>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="12,16,12,0">

                        <Button Content="🏠  Trang Chủ"
                                Style="{StaticResource NavButton}"
                                Command="{Binding ShowTrangChuCommand}"/>

                        <Expander Header="📁  Danh mục" Style="{StaticResource SidebarExpander}">
                            <StackPanel>
                                <Button Content="Hãng xe" Style="{StaticResource SubNavButton}" Command="{Binding ShowHangXeCommand}"/>
                                <Button Content="Kho xe máy" Style="{StaticResource SubNavButton}" Command="{Binding ShowXeMayCommand}"/>
                                <Button Content="Nhà cung cấp" Style="{StaticResource SubNavButton}" Command="{Binding ShowNhaCungCapCommand}"/>
                                <Button Content="Khách hàng" Style="{StaticResource SubNavButton}" Command="{Binding ShowKhachHangCommand}"/>
                                <Button Content="Nhân viên" Style="{StaticResource SubNavButton}" Command="{Binding ShowNhanVienCommand}"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="📦  Nghiệp vụ" Style="{StaticResource SidebarExpander}">
                            <StackPanel>
                                <Button Content="Hóa đơn bán hàng" Style="{StaticResource SubNavButton}" Command="{Binding ShowHoaDonCommand}"/>
                            </StackPanel>
                        </Expander>

                        <Expander Header="⚙️  Hệ thống" Style="{StaticResource SidebarExpander}" IsExpanded="False">
                            <StackPanel>
                                <Button Content="Sao lưu / Phục hồi" Style="{StaticResource SubNavButton}" Command="{Binding ShowHeThongCommand}"/>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Logout -->
                <StackPanel Grid.Row="2" Margin="12,0,12,20">
                    <Border Height="1" Background="#1E293B" Margin="4,0,4,12"/>
                    <Button Content="⏻  Đăng Xuất"
                            Style="{StaticResource LogoutButton}"
                            Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== NỘI DUNG CHÍNH ===== -->
        <Border Grid.Column="1" Background="#F1F5F9">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header Phải -->
                <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <!-- User Logo/Avatar -->
                            <Button Command="{Binding ShowProfileCommand}" 
                                    Style="{StaticResource NavButton}" Padding="4" Height="Auto" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Thông tin tài khoản">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentUserDisplayName}" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" Foreground="#475569" FontSize="14"/>
                                    <Ellipse Width="40" Height="40" Stroke="#CBD5E1" StrokeThickness="1">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding CurrentUserAvatar, Converter={StaticResource ImagePathConverter}, FallbackValue='/Images/Icons/user.png', TargetNullValue='/Images/Icons/user.png'}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Vùng hiển thị View -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="24"/>
            </Grid>
        </Border>
    </Grid>
</Window>
