<UserControl x:Class="QLXeMay.Views.HeThong.BackupRestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="#F1F5F9">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Header -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,40">
                <TextBlock Text="HỆ THỐNG DỮ LIỆU"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1E293B" HorizontalAlignment="Center"/>
                <TextBlock Text="Bảo vệ an toàn dữ liệu của bạn bằng cách sao lưu thường xuyên"
                           FontSize="13" Foreground="#64748B"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 2 Cards -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <!-- Card Sao lưu -->
                <Border Background="White" CornerRadius="16" Width="280" Margin="0,0,24,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                          Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel Margin="28,30">
                        <!-- Icon circle -->
                        <Border Background="#DBEAFE" CornerRadius="50"
                                Width="72" Height="72"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="💾" FontSize="36"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Sao lưu dữ liệu"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#1E293B"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Tạo bản sao an toàn toàn bộ dữ liệu hiện hành về máy tính."
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="#64748B" FontSize="13"
                                   Margin="0,0,0,24"/>
                        <Button Content="💾  SAO LƯU NGAY"
                                Command="{Binding BackupCommand}"
                                Height="42" Style="{StaticResource PrimaryButton}"
                                FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Card Phục hồi -->
                <Border Background="White" CornerRadius="16" Width="280">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                          Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel Margin="28,30">
                        <Border Background="#FEF3C7" CornerRadius="50"
                                Width="72" Height="72"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="🔄" FontSize="36"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Phục hồi dữ liệu"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#1E293B"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Khôi phục lại hệ thống từ tập tin sao lưu (.bak) trước đó."
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="#64748B" FontSize="13"
                                   Margin="0,0,0,24"/>
                        <Button Content="🔄  PHỤC HỒI" Height="42"
                                Command="{Binding RestoreCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#D97706" FontSize="13"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
