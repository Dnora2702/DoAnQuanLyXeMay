<Window x:Class="QLXeMay.Views.Auth.ChangePassView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:QLXeMay.ViewModels.Auth"
        Title="Đổi Mật Khẩu" Height="500" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">
    <Window.DataContext>
        <vm:ChangePassViewModel/>
    </Window.DataContext>

    <Border CornerRadius="16" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4"
                              Color="#000000" Opacity="0.20"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1E3A8A" Offset="0"/>
                        <GradientStop Color="#3B82F6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" Margin="24,0">
                    <TextBlock Text="ĐỔI MẬT KHẨU"
                               FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding HeaderSubtitle}"
                               FontSize="11" Foreground="#BFDBFE"/>
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="28,20,28,24">

                <TextBlock Text="Mật khẩu hiện tại *" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="txtOldPass" Style="{StaticResource PlainPasswordBox}"/>
                </Border>

                <TextBlock Text="Mật khẩu mới * (ít nhất 6 ký tự)" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="txtNewPass" Style="{StaticResource PlainPasswordBox}"/>
                </Border>

                <TextBlock Text="Xác nhận mật khẩu mới *" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="txtConfirmPass" Style="{StaticResource PlainPasswordBox}"/>
                </Border>

                <!-- Error / Success -->
                <Border Background="#FEE2E2" CornerRadius="8" Padding="12,10" Margin="0,0,0,10"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>
                <Border Background="#D1FAE5" CornerRadius="8" Padding="12,10" Margin="0,0,0,10"
                        Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#059669" FontSize="13"/>
                </Border>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="XÁC NHẬN" Height="42"
                            Click="BtnConfirm_Click" Style="{StaticResource PrimaryButton}"/>
                    <Button Grid.Column="2" Content="Đóng" Height="42"
                            Click="btnClose_Click" Style="{StaticResource GhostButton}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
