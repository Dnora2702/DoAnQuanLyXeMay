<Window x:Class="QLXeMay.Views.Auth.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:QLXeMay.ViewModels.Auth"
        xmlns:helper="clr-namespace:QLXeMay.Helpers"
        mc:Ignorable="d"
        Title="Đăng Ký Tài Khoản" Height="620" Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">
    <Window.DataContext>
        <vm:RegisterViewModel/>
    </Window.DataContext>

    <Border CornerRadius="16" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4"
                              Color="#000000" Opacity="0.20"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header gradient -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1E3A8A" Offset="0"/>
                        <GradientStop Color="#3B82F6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" Margin="24,0">
                    <TextBlock Text="ĐĂNG KÝ TÀI KHOẢN"
                               FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Tạo tài khoản nhân viên mới"
                               FontSize="11" Foreground="#BFDBFE"/>
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="28,20,28,24">

                <TextBlock Text="Tên đăng nhập *" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PlainTextBox}"/>
                </Border>

                <TextBlock Text="Họ và tên *" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PlainTextBox}"/>
                </Border>

                <TextBlock Text="Số điện thoại *" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PlainTextBox}"/>
                </Border>

                <TextBlock Text="Mật khẩu * (ít nhất 6 ký tự)" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="txtPassword" Style="{StaticResource PlainPasswordBox}"
                                 helper:PasswordBoxHelper.Attach="True"
                                 helper:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>

                <TextBlock Text="Xác nhận mật khẩu *" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="txtConfirmPassword" Style="{StaticResource PlainPasswordBox}"
                                 helper:PasswordBoxHelper.Attach="True"
                                 helper:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>

                <!-- Error / Success -->
                <Border Background="#FEE2E2" CornerRadius="8" Padding="12,10" Margin="0,0,0,10"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>
                <Border Background="#D1FAE5" CornerRadius="8" Padding="12,10" Margin="0,0,0,10"
                        Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#059669" FontSize="13"/>
                </Border>

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ĐĂNG KÝ" Height="42"
                            Command="{Binding RegisterCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                    <Button Grid.Column="2" Content="Đóng" Height="42"
                            Click="btnClose_Click" Style="{StaticResource GhostButton}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
