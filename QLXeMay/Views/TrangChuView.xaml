<UserControl x:Class="QLXeMay.Views.TrangChuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F1F5F9">
        <StackPanel Margin="8">

            <!-- Header -->
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="TỔNG QUAN HỆ THỐNG"
                           FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Thống kê tổng hợp hoạt động kinh doanh"
                           FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- KPI Cards -->
            <WrapPanel>

                <!-- Doanh thu -->
                <Border Width="260" Height="140" Background="White"
                        CornerRadius="14" Margin="0,0,18,18" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                          Color="#94A3B8" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Accent bar trái -->
                        <Border Width="4" HorizontalAlignment="Left"
                                CornerRadius="2" Background="#059669"/>
                        <StackPanel Margin="16,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#D1FAE5" CornerRadius="8"
                                        Width="36" Height="36">
                                    <TextBlock Text="💰" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="TỔNG DOANH THU"
                                       Foreground="#64748B" FontSize="11"
                                       FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} đ}"
                                       Foreground="#059669" FontSize="22"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hóa đơn -->
                <Border Width="260" Height="140" Background="White"
                        CornerRadius="14" Margin="0,0,18,18" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                          Color="#94A3B8" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left"
                                CornerRadius="2" Background="#2563EB"/>
                        <StackPanel Margin="16,0,0,0">
                            <Border Background="#DBEAFE" CornerRadius="8"
                                    Width="36" Height="36">
                                <TextBlock Text="🧾" FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="SỐ HÓA ĐƠN ĐÃ BÁN"
                                       Foreground="#64748B" FontSize="11"
                                       FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <TextBlock Text="{Binding TongHoaDon}"
                                       Foreground="#2563EB" FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Khách hàng -->
                <Border Width="260" Height="140" Background="White"
                        CornerRadius="14" Margin="0,0,18,18" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                          Color="#94A3B8" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left"
                                CornerRadius="2" Background="#D97706"/>
                        <StackPanel Margin="16,0,0,0">
                            <Border Background="#FEF3C7" CornerRadius="8"
                                    Width="36" Height="36">
                                <TextBlock Text="👥" FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="TỔNG KHÁCH HÀNG"
                                       Foreground="#64748B" FontSize="11"
                                       FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <TextBlock Text="{Binding TongKhachHang}"
                                       Foreground="#D97706" FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Tồn kho -->
                <Border Width="260" Height="140" Background="White"
                        CornerRadius="14" Margin="0,0,18,18" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                          Color="#94A3B8" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left"
                                CornerRadius="2" Background="#DC2626"/>
                        <StackPanel Margin="16,0,0,0">
                            <Border Background="#FEE2E2" CornerRadius="8"
                                    Width="36" Height="36">
                                <TextBlock Text="🏍️" FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="XE MÁY TỒN KHO"
                                       Foreground="#64748B" FontSize="11"
                                       FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <TextBlock Text="{Binding TongXeTonKho}"
                                       Foreground="#DC2626" FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </WrapPanel>

            <!-- FOOTER -->
            <Border Background="White" CornerRadius="12" Padding="30" Margin="0,20,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Color="#94A3B8" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Column 1: Hỗ trợ Khách Hàng -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Hỗ trợ Khách Hàng" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,16"/>
                            <Button Content="Liên hệ Hỗ trợ" Command="{Binding ShowSupportCommand}" 
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Foreground="#2563EB" Padding="0,4" FontSize="14" Cursor="Hand"/>
                        </StackPanel>

                        <!-- Column 2: Về XE MÁY PRO -->
                        <StackPanel Grid.Column="1" Margin="0,0,20,0">
                            <TextBlock Text="Về XE MÁY PRO" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,16"/>
                            <Button Content="Giới thiệu" Command="{Binding ShowIntroCommand}" 
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Foreground="#2563EB" Padding="0,4" FontSize="14" Margin="0,0,0,8" Cursor="Hand"/>
                            <Button Content="Chính sách bảo mật" Command="{Binding ShowPrivacyCommand}" 
                                    Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Foreground="#2563EB" Padding="0,4" FontSize="14" Cursor="Hand"/>
                        </StackPanel>

                        <!-- Column 3: Liên Kết -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Liên kết" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🌐 Facebook" FontSize="14" Foreground="#475569" Margin="0,0,16,0" Cursor="Hand"/>
                                <TextBlock Text="📸 Instagram" FontSize="14" Foreground="#475569" Cursor="Hand"/>
                            </StackPanel>
                            <TextBlock Text="Email: nguyenvantuong2605@gmail.com" Foreground="#475569" FontSize="13" Margin="0,0,0,8"/>
                            <TextBlock Text="Địa Chỉ: Trụ sở chính của Trường Đại học Công Thương TP.HCM (HUIT) tọa lạc tại 140 Lê Trọng Tấn, Phường Tây Thạnh, Quận Tân Phú, TP. Hồ Chí Minh" 
                                       Foreground="#475569" FontSize="13" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#E2E8F0" Margin="0,24,0,24"/>

                    <TextBlock Foreground="#64748B" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" LineHeight="20">
                        CÔNG TY TNHH XE MÁY PRO - Người đại diện theo pháp luật: Nguyễn Văn Tưởng; TTLH: 0984371025, Kiêm quản lý : Bùi Hoài Vũ , Quách Quốc Anh , tất cả do Sở DT &amp; ĐH Công Thương TP.HCM cấp ngày 05/27/2026;<LineBreak/>
                        Chịu trách nhiệm nội dung: Ngọc Phát.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
