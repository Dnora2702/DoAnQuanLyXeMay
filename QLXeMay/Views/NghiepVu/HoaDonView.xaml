<UserControl x:Class="QLXeMay.Views.NghiepVu.HoaDonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F1F5F9">
        <StackPanel Margin="8">

            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="LẬP HÓA ĐƠN BÁN HÀNG"
                           FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Tạo hóa đơn và xử lý thanh toán"
                           FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="6*"/>
                </Grid.ColumnDefinitions>

                <!-- Cột trái: form chọn hàng -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Padding="20" Margin="0,0,16,0" VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                          Color="#94A3B8" Opacity="0.12"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="THÔNG TIN ĐƠN HÀNG"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#475569" Margin="0,0,0,16"/>

                        <TextBlock Text="Khách Hàng *" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <ComboBox ItemsSource="{Binding ListKhachHang}"
                                      SelectedItem="{Binding SelectedKhachHang}"
                                      DisplayMemberPath="TenKH"
                                      Padding="12,9" BorderThickness="0"
                                      Background="Transparent"/>
                        </Border>

                        <Border Background="#F1F5F9" Height="1" Margin="0,4,0,18"/>

                        <TextBlock Text="Chọn Xe Máy *" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <ComboBox ItemsSource="{Binding ListXeMay}"
                                      SelectedItem="{Binding SelectedXe}"
                                      Padding="12,9" BorderThickness="0"
                                      Background="Transparent">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding TenXe}"/>
                                            <Run Text=" — Tồn kho: " Foreground="#94A3B8"/>
                                            <Run Text="{Binding SoLuong}" Foreground="#DC2626" FontWeight="Bold"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>

                        <TextBlock Text="Số lượng mua *" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox Text="{Binding SoLuongBan, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"/>
                        </Border>

                        <Button Content="＋  THÊM VÀO GIỎ"
                                Command="{Binding AddToCartCommand}"
                                Style="{StaticResource GhostButton}"
                                Foreground="#2563EB" BorderBrush="#2563EB"
                                Height="42" Margin="0,6,0,0"
                                FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Cột phải: giỏ hàng -->
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                          Color="#94A3B8" Opacity="0.12"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="CHI TIẾT GIỎ HÀNG"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>

                        <Border CornerRadius="10" ClipToBounds="True">
                            <Border.Clip>
                                <RectangleGeometry RadiusX="10" RadiusY="10"
                                                   Rect="0,0,2000,270"/>
                            </Border.Clip>
                            <DataGrid ItemsSource="{Binding GioHang}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Height="270">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên Xe"    Binding="{Binding XeMay.TenXe}"                                  Width="*"/>
                                    <DataGridTextColumn Header="Số Lượng"  Binding="{Binding SoLuong}"                                       Width="90"/>
                                    <DataGridTextColumn Header="Đơn Giá"   Binding="{Binding DonGia,   StringFormat={}{0:N0} đ}"             Width="130"/>
                                    <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0} đ}"           Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Tổng tiền + buttons -->
                        <Border Background="#F8FAFC" CornerRadius="10"
                                Padding="16,14" Margin="0,16,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,0,0,14">
                                    <TextBlock Text="TỔNG THANH TOÁN:"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#475569"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}"
                                               FontSize="26" FontWeight="Bold"
                                               Foreground="#DC2626" Margin="12,0,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Content="🖨️  IN HÓA ĐƠN"
                                            Command="{Binding XuatHoaDonCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="#D97706" Width="140" Height="44"
                                            Margin="0,0,12,0"/>
                                    <Button Content="✔  THANH TOÁN"
                                            Command="{Binding ThanhToanCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="#059669" Width="140" Height="44"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
