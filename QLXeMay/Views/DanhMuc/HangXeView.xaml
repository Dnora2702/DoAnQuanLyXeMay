<UserControl x:Class="QLXeMay.Views.DanhMuc.HangXeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F1F5F9">
        <StackPanel Margin="8">

            <!-- Tiêu đề trang -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="QUẢN LÝ HÃNG XE"
                           FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Thêm, sửa, xóa danh mục hãng xe máy"
                           FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form nhập liệu -->
            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Tên hãng xe *" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}" Width="420"
                                HorizontalAlignment="Left" Margin="0,0,0,0">
                            <TextBox Text="{Binding TenHang, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,0,0">
                        <Button Content="＋  THÊM MỚI"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="110" Height="40"/>
                        <Button Content="✎  CẬP NHẬT"
                                Command="{Binding UpdateCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#059669" Width="110" Height="40"
                                Margin="10,0,0,0"/>
                        <Button Content="✕  XÓA"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#DC2626" Width="90" Height="40"
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Background="White" CornerRadius="12" Padding="0"
                    Width="700" HorizontalAlignment="Left">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <Border.Clip>
                    <RectangleGeometry RadiusX="12" RadiusY="12"
                                       Rect="0,0,700,420"/>
                </Border.Clip>
                <DataGrid ItemsSource="{Binding ListHangXe}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Height="420">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Hãng"   Binding="{Binding MaHang}" Width="150"/>
                        <DataGridTextColumn Header="Tên Hãng Xe" Binding="{Binding TenHang}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
