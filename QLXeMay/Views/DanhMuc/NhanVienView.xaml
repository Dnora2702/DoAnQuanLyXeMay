<UserControl x:Class="QLXeMay.Views.DanhMuc.NhanVienView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F1F5F9">
        <StackPanel Margin="8">

            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="QUẢN LÝ NHÂN VIÊN"
                           FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Quản lý thông tin nhân viên cửa hàng"
                           FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form -->
            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,20">
                        <TextBlock Text="Tên nhân viên *" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}" Margin="0,0,0,0">
                            <TextBox Text="{Binding TenNV, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,14,20">
                        <TextBlock Text="Số điện thoại" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}" Margin="0,0,0,0">
                            <TextBox Text="{Binding SDT, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3" Margin="0,0,0,20">
                        <TextBlock Text="Địa chỉ" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}" Margin="0,0,0,0">
                            <TextBox Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,14,0">
                        <TextBlock Text="Tên đăng nhập" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}" Margin="0,0,0,0">
                            <TextBox Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Margin="0,0,0,20">
                        <TextBlock Text="Mật khẩu" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}" Margin="0,0,0,0">
                            <TextBox Text="{Binding MatKhau, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"
                                     ToolTip="Nhập mật khẩu mới. Nếu để trống khi sửa sẽ giữ nguyên MK cũ."/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="＋  THÊM MỚI"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="110" Height="40"/>
                        <Button Content="✎  CẬP NHẬT"
                                Command="{Binding UpdateCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#059669" Width="110" Height="40"
                                Margin="10,0,0,0"/>
                        <Button Content="✕  XÓA"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#DC2626" Width="80" Height="40"
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <Border.Clip>
                    <RectangleGeometry RadiusX="12" RadiusY="12"
                                       Rect="0,0,2000,420"/>
                </Border.Clip>
                <DataGrid ItemsSource="{Binding ListNhanVien}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Height="420">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV"         Binding="{Binding MaNV}"        Width="80"/>
                        <DataGridTextColumn Header="Tên Nhân Viên" Binding="{Binding TenNV}"       Width="200"/>
                        <DataGridTextColumn Header="Số Điện Thoại" Binding="{Binding SDT}"         Width="120"/>
                        <DataGridTextColumn Header="Địa Chỉ"       Binding="{Binding DiaChi}"      Width="*"/>
                        <DataGridTextColumn Header="Tài Khoản"     Binding="{Binding TenDangNhap}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
