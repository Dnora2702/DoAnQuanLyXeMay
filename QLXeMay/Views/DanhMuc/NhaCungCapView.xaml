<UserControl x:Class="QLXeMay.Views.DanhMuc.NhaCungCapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F1F5F9">
        <StackPanel Margin="8">

            <!-- Tiêu đề trang -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="QUẢN LÝ NHÀ CUNG CẤP"
                           FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Thêm, sửa, xóa danh mục nhà cung cấp"
                           FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form nhập liệu -->
            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Tên nhà cung cấp *" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}">
                                    <TextBox Text="{Binding TenNCC, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainTextBox}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Số điện thoại" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}">
                                    <TextBox Text="{Binding SDT, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainTextBox}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Địa chỉ" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}">
                                    <TextBox Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainTextBox}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Bottom" Margin="0,0,0,14">
                        <Button Content="＋  THÊM"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="90" Height="40"/>
                        <Button Content="✎  SỬA"
                                Command="{Binding UpdateCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#059669" Width="90" Height="40"
                                Margin="10,0,0,0"/>
                        <Button Content="✕  XÓA"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#DC2626" Width="90" Height="40"
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Background="White" CornerRadius="12" Padding="0"
                    HorizontalAlignment="Stretch">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <Border.Clip>
                    <RectangleGeometry RadiusX="12" RadiusY="12"
                                       Rect="0,0,1500,420"/>
                </Border.Clip>
                <DataGrid ItemsSource="{Binding ListNhaCungCap}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Height="420" Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NCC" Binding="{Binding MaNCC}" Width="100"/>
                        <DataGridTextColumn Header="Tên Nhà Cung Cấp" Binding="{Binding TenNCC}" Width="*"/>
                        <DataGridTextColumn Header="Số Điện Thoại" Binding="{Binding SDT}" Width="150"/>
                        <DataGridTextColumn Header="Địa Chỉ" Binding="{Binding DiaChi}" Width="250"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
