<UserControl x:Class="QLXeMay.Views.DanhMuc.XeMayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:QLXeMay.Helpers">
    <UserControl.Resources>
        <helpers:ImagePathConverter x:Key="ImagePathConverter" />
    </UserControl.Resources>
    <Grid Background="#F1F5F9">
        <StackPanel Margin="8">

            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="QUẢN LÝ KHO XE"
                           FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Quản lý kho xe máy, hình ảnh và giá bán"
                           FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form nhập liệu -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ảnh -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <Border BorderBrush="#E2E8F0" BorderThickness="1.5"
                                CornerRadius="10" Height="150" Background="#F8FAFC"
                                Margin="0,0,0,10" ClipToBounds="True">
                            <Image Source="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                        </Border>
                        <Button Content="📷  Chọn Ảnh"
                                Command="{Binding ChonAnhCommand}"
                                Style="{StaticResource GhostButton}"
                                Height="36" FontSize="12"/>
                    </StackPanel>

                    <!-- Fields -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="Tên Xe *" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                <TextBox Text="{Binding TenXe, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainTextBox}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Hãng Xe *" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                <ComboBox ItemsSource="{Binding ListHangXe}"
                                          SelectedItem="{Binding SelectedHangXe}"
                                          DisplayMemberPath="TenHang"
                                          Padding="12,9" BorderThickness="0"
                                          Background="Transparent" FontSize="14"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="Số Lượng Kho" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                <TextBox Text="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainTextBox}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="Giá Bán (VNĐ)" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                <TextBox Text="{Binding GiaBan, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainTextBox}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="＋  THÊM VÀO KHO"
                                    Command="{Binding AddCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="160" Height="40"/>
                            <Button Content="✏️  SỬA THÔNG TIN"
                                    Command="{Binding EditCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#F59E0B"
                                    Width="160" Height="40" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Tìm kiếm + danh sách card -->
            <Border Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2"
                                      Color="#94A3B8" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Thanh tìm kiếm -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍  Tìm kiếm xe:"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Foreground="#475569" Margin="0,0,12,0"/>
                        <Border Grid.Column="1" BorderBrush="#CBD5E1" BorderThickness="1.5"
                                CornerRadius="8" Background="White">
                            <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainTextBox}"/>
                        </Border>
                        
                        <TextBlock Grid.Column="2" Text="💰 Lọc theo giá:"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Foreground="#475569" Margin="20,0,12,0"/>
                        <Border Grid.Column="3" BorderBrush="#CBD5E1" BorderThickness="1.5"
                                CornerRadius="8" Background="White">
                            <ComboBox ItemsSource="{Binding ListPriceFilters}"
                                      SelectedItem="{Binding SelectedPriceFilter}"
                                      Padding="12,9" BorderThickness="0"
                                      Background="Transparent" FontSize="14"/>
                        </Border>
                        
                        <Button Grid.Column="4" Content="📄 XUẤT PDF"
                                Command="{Binding ExportPdfCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#10B981" Width="120" Height="36"
                                Margin="20,0,0,0" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Card grid -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="280">
                        <ListBox ItemsSource="{Binding ListXeMay}"
                                 SelectedItem="{Binding SelectedItem}"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="200" Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="5"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="CardBorder"
                                                        Background="White" CornerRadius="12"
                                                        BorderBrush="#E2E8F0" BorderThickness="1.5"
                                                        Margin="5">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                                          Opacity="0.08" Color="#000000"/>
                                                    </Border.Effect>
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#2563EB"/>
                                                        <Setter TargetName="CardBorder" Property="Background" Value="#EFF6FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="#93C5FD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="220">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                                Background="#F1F5F9" ClipToBounds="True">
                                            <Image Source="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Row="1" Margin="10,8">
                                            <TextBlock Text="{Binding TenXe}" FontWeight="Bold"
                                                       FontSize="13" Foreground="#1E293B"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding HangXe.TenHang}"
                                                       FontSize="11" Foreground="#94A3B8"
                                                       Margin="0,2,0,6"/>
                                            <Grid>
                                                <TextBlock Text="{Binding GiaBan, StringFormat={}{0:N0} đ}"
                                                           FontWeight="Bold" Foreground="#DC2626"
                                                           HorizontalAlignment="Left" FontSize="12"/>
                                                <TextBlock Text="{Binding SoLuong, StringFormat=Kho: {0}}"
                                                           FontSize="11" Foreground="#64748B"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
